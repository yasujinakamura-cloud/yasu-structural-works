---
const SERIES = [
  {
    title: "STRUCTURE",
    statement: "LIGHT IS FORCE. STRUCTURE IS RESISTANCE.",
    href: "/series/structure/intro/",
    thumb: "/series/structure/images/001.jpg",
  },
  {
    title: "NOCTURNE",
    statement: "NIGHT HOLDS ITS SHAPE.",
    href: "/series/nocturne/intro/",
    thumb: "/series/nocturne/images/001.jpg",
  },
  {
    title: "VELOCITY",
    statement: "TIME LEAVES A TRACE.",
    href: "/series/velocity/intro/",
    thumb: "/series/velocity/images/001.jpg",
  },
  {
    title: "LIGHT",
    statement: "LIGHT DECIDES WHAT EXISTS.",
    href: "/series/light/intro/",
    thumb: "/series/light/images/001.jpg",
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>YASU — Portfolio</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/assets/theme.css" />
</head>
<body>
  <main class="wrap">
    <div class="topbar">
      <a class="toplink" href="mailto:yasuji.nakamura@gmail.com">CONTACT</a>
    </div>

    <section class="hero" aria-label="Statement">
      <h1>LIGHT IS FORCE. STRUCTURE IS RESISTANCE.</h1>
      <p>Studies in light and form. Works by Yasu Nakamura.</p>
      <div class="sub">ENTER A SERIES</div>
      <div class="enterline">
        <a class="btn" href="#categories">ENTER →</a>
      </div>
    </section>

    <div id="categories" class="section-k">CATEGORIES / ENTER A SERIES</div>

    <section class="grid" aria-label="Series">
      {SERIES.map((s)=>(
        <article class="card">
          <div class="bg" style={`background-image:url(${s.thumb});`}></div>
          <a class="hit" href={s.href} aria-label={`Enter ${s.title}`}></a>
          <div class="meta">
            <div class="kicker">SERIES</div>
            <div class="title">{s.title}</div>
            <div class="stmt">{s.statement}</div>
          </div>
          <div class="enter">ENTER →</div>
        </article>
      ))}
    </section>
  </main>
</body>
</html>